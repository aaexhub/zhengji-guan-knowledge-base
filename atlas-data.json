  "relations": [
    {
      "id": "rel1",
      "name": "稳和进的关系",
      "short": "稳和进",
      "intro": "稳和进辩证统一、相辅相成。稳中求进工作总基调是我们治国理政的重要原则。稳是大局、是基础、是前提，进是方向、是动能、是保障。",
      "aspect1": {
        "label": "以稳筑牢发展根基",
        "text": "当今世界，多重挑战和危机交织叠加，我们必须保持战略定力，把稳定大局、稳定预期、稳定增长放在突出位置。党员干部要尊重客观规律和发展实际，不搞超越阶段的大干快上，不作寅吃卯粮的短期决策，避免因政策朝令夕改造成资源浪费、贻误发展。"
      },
      "aspect2": {
        "label": "以进激发内生动力",
        "text": "稳不是无所作为、停滞不前，而是在稳定基础上实现更高质量、更有效率、更可持续的发展。要找准进的切入点和发力点，牢牢把握高质量发展这个首要任务，在科技创新、产业升级、民生改善等关键领域主动作为、攻坚克难。"
      },
      "related_cats": [
        "cat1",
        "cat2",
        "cat3"
      ]
    },
    {
      "id": "rel2",
      "name": "立和破的关系",
      "short": "立和破",
      "intro": "破与立构成事物对立统一的两个方面。调整政策和推动改革要把握好时度效，坚持先立后破、稳扎稳打。",
      "aspect1": {
        "label": "以立固根本、强支撑",
        "text": "立是立足长远、夯实基础，是把符合新发展理念、符合群众利益、符合长远大局的民生工程建起来、立得住。要立高质量发展导向、立为民服务宗旨、立系统施治策略、立绿色发展理念、立实干担当作风。"
      },
      "aspect2": {
        "label": "以破除积弊、开新局",
        "text": "破是破除障碍、革除弊端，打破思维定势和路径依赖。要坚决破除唯GDP、重显绩轻潜绩、重短期轻长远等错误政绩观，破除资源浪费、生态破坏、粗放发展的旧模式，破除推诿扯皮、敷衍塞责的坏风气。"
      },
      "related_cats": [
        "cat2",
        "cat3",
        "cat4"
      ]
    },
    {
      "id": "rel3",
      "name": "虚和实的关系",
      "short": "虚和实",
      "intro": "虚与实映照党性作风、检验政绩成色。业绩都是干出来的，真干才能真出业绩、出真业绩。虚指向理论指引、思想引领、价值导向，实指向实践行动、具体举措、实际成效。",
      "aspect1": {
        "label": "强化理论武装，以虚领航定向",
        "text": "正确政绩观首先源于科学理论指引。要深学笃行习近平总书记关于树立和践行正确政绩观的重要论述，深刻把握政绩为谁而树、树什么样的政绩、靠什么树政绩这一根本性问题。以理论清醒保证政绩观端正，以政治坚定防止政绩观跑偏错位。"
      },
      "aspect2": {
        "label": "崇尚实干担当，以实检验成效",
        "text": "一切政绩最终要靠实践、靠实干、靠实效来体现。要坚决反对形式主义、官僚主义，不搞花拳绣腿、不做表面文章、不搞形象工程、政绩工程，把心思用在干事创业上，把精力投入到为民服务中。"
      },
      "related_cats": [
        "cat1",
        "cat3",
        "cat4",
        "cat5"
      ]
    },
    {
      "id": "rel4",
      "name": "标和本的关系",
      "short": "标和本",
      "intro": "治标与治本体现着工作作风和工作方法，是衡量政绩观是否正确的重要标尺。治标是应急之举、解难之方，治本是源头治理、综合治理。",
      "aspect1": {
        "label": "以治标快速破题，化解突出矛盾",
        "text": "治标是治本的前提，通过治标精准把握问题表象，为治本找准靶向。面对风险隐患集中的突出领域和群众反映强烈的痛点难点堵点问题，党员干部要反应迅速、果断出手、及时处置，快速稳定局面以回应民生关切。"
      },
      "aspect2": {
        "label": "以治本固本培元，健全长效机制",
        "text": "解决根本性、长远性、全局性问题，关键在治本。要透过现象看本质，从思想认识、制度规则、责任体系、权力运行上查根源、抓整改，把实践中的有效经验上升为体制机制，堵塞管理漏洞、补齐治理短板。"
      },
      "related_cats": [
        "cat3",
        "cat5",
        "cat6"
      ]
    },
    {
      "id": "rel5",
      "name": "近和远的关系",
      "short": "近和远",
      "intro": "当前与长远、显绩与潜绩，是新时代树立和践行正确政绩观必须处理好的重大关系。近与远的统一，就是兼顾当下见效与长远受益，统筹发展速度与发展质量。",
      "aspect1": {
        "label": "立足当前，抓实眼前显绩",
        "text": "民生无小事，枝叶总关情。对群众关于就业、教育、医疗、养老、住房等迫切需求，对区域发展、项目建设、风险防范等紧迫任务，必须马上就办、真抓实干，以看得见、摸得着的变化回应群众期盼。"
      },
      "aspect2": {
        "label": "着眼长远，厚植长期潜绩",
        "text": "不谋万世者，不足谋一时。党员干部要保持历史耐心，胸怀功成不必在我、功成必定有我的境界，坚持一张蓝图绘到底、一茬接着一茬干，重视科技创新、人才培养、生态保护、文化传承、基层治理等潜绩工程。"
      },
      "related_cats": [
        "cat1",
